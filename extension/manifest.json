{
  "manifest_version": 3,

  "name": "ATPLQ Discord Presence",

  "version": "1.0",

  "permissions": [],

  "host_permissions": [
    "https://app.atplquestions.com/*",
    "http://localhost:3000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://app.atplquestions.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}